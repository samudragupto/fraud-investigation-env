# Hackathon Rule: Read API credentials from OPENAI_API_KEY
# Use your Hugging Face Token (hf_...) here
OPENAI_API_KEY=hf_your_huggingface_token_here

# The new Hugging Face OpenAI-compatible router
OPENAI_BASE_URL=https://router.huggingface.co/hf-inference/v1

# Meta Llama Model
MODEL_NAME=meta-llama/Meta-Llama-3.1-8B-Instruct

# Local Environment URL
ENV_URL=http://localhost:7860